generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"] // <--- MUST HAVE THIS
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}



model ginivo_company {
  company_id                        String     @id @db.VarChar(36)
  name                              String     @db.VarChar(100)
  email                             String?    @db.VarChar(250)
  phone                             String?    @db.VarChar(20)
  address                           String?    @db.Text    
  country                           String?    @db.VarChar(100)
  website                           String?    @db.VarChar(100)
  tax_no                            String?    @db.VarChar(20)
  created_date                      DateTime   @db.Timestamp(6) @default(now())
  creator_user_id                   String     @db.VarChar(36)
  modified_date                     DateTime   @db.Timestamp(6)
  modifier_user_id                  String     @db.VarChar(36)
  country_code                      String?    @db.VarChar(10)


}


model giniapp {
  app_id                            String   @id @db.VarChar(36)
  app_name                          String   @db.VarChar(100)
  app_code                          String   @db.VarChar(20)
  api_key                           String?  @db.VarChar(50)

  is_active                         Int
  is_live                           Int

  created_date                      DateTime? @db.Timestamptz(6)
  create_by                         String?   @db.VarChar(36)

  license_private_key               String?
  license_public_key                String?
  generated_license                 String?

  authorized_urls                   String?
}


model giniapp_account {
  account_id                        String     @id @db.VarChar(36)
  user_id                           String     @db.VarChar(36)
  firstname                         String?    @db.VarChar(50)
  lastname                          String?    @db.VarChar(50)
  email                             String     @db.VarChar(250)
  phone                             String?    @db.VarChar(20)
  account_status                    String     @db.VarChar(20)
  created_date                      DateTime   @db.Timestamp(6) @default(now())
  creator_user_id                   String     @db.VarChar(36)
  modified_date                     DateTime   @db.Timestamp(6)
  modifier_user_id                  String     @db.VarChar(36)
  is_deactivated                    Int        @default(0)
  deactivation_reason               String?
  
  @@index([user_id], map: "idx_giniapp_account_on_user_id")
}


